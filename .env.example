PORT=3000

# Chemin vers la base SQLite (par défaut : data/budget.db)
DB_PATH=data/budget.db

# Mettre à true si l'app est servie en HTTPS (Cloudflare tunnel, etc.)
SECURE_COOKIES=false

# Créé automatiquement au premier démarrage si aucun utilisateur n'existe.
# Peut être retiré après le premier lancement.
INITIAL_USERNAME=xenfroz
INITIAL_PASSWORD=change-me-to-a-strong-password

# Webhook de déploiement automatique (optionnel)
WEBHOOK_PORT=9000
WEBHOOK_SECRET=change-me-to-another-strong-secret
